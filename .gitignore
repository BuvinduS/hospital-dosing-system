# ============================================================
#  .gitignore — IoT Chemical Dosing System
#  PlatformIO + Wokwi + VS Code
# ============================================================

# ── PlatformIO build output ──────────────────────────────────
.pio/
.pioenvs/
.piolibdeps/

# ── PlatformIO workspace ─────────────────────────────────────
.pio/build/
.pio/libdeps/
.pio/packages/

# ── VS Code ──────────────────────────────────────────────────
.vscode/*
# Keep launch.json and extensions.json if present — useful for
# sharing debug config and recommended extensions across the team
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/c_cpp_properties.json
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# ── Wokwi ────────────────────────────────────────────────────
# Do NOT ignore diagram.json or wokwi.toml — these are source files
# Ignore any local Wokwi cache if it appears
.wokwi-cache/

# ── Operating system files ───────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ── Compiled objects and binaries ────────────────────────────
*.o
*.a
*.d
*.elf
*.bin
*.hex
*.map

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Python (if any tooling scripts are added later) ──────────
__pycache__/
*.py[cod]
*.pyo
.env
venv/
env/

# ── Node.js (if any dashboard tooling is added later) ────────
node_modules/
npm-debug.log*

# ── Temporary and backup files ───────────────────────────────
*.tmp
*.bak
*.swp
*.orig